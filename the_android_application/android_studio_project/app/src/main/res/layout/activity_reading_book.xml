<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="10dp"
        android:layout_weight="1"
        android:background="@drawable/bg_surface_panel"
        android:orientation="horizontal"
        android:padding="8dp">

        <Button
            android:id="@+id/button_go_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_reading_button"
            android:foreground="@drawable/icon_home"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/button_switch_view"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_reading_button"
            android:foreground="@drawable/icon_switch_view"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/button_book_statistics"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_reading_button"
            android:foreground="@drawable/icon_info"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/button_play_pause"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_reading_button"
            android:foreground="@drawable/icon_play_pause"
            android:textColor="@color/white" />

    </LinearLayout>
    <TextView
        android:id="@+id/text_book_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="10dp"
        android:layout_weight="3"
        android:background="@drawable/bg_surface_panel"
        android:gravity="center"
        android:padding="16dp"
        android:text="word will be here"
        android:textColor="@color/white"
        android:textSize="44sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="4"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="@drawable/bg_surface_panel"
            android:padding="8dp"
            android:layout_weight="1"
            android:layout_marginBottom="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_decrease_speed"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_reading_button"
                android:foreground="@drawable/icon_arrow_left"
                android:textColor="@color/white" />

            <ImageView
                android:id="@+id/icon_view_speed"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="6dp"
                android:layout_weight="1"
                android:padding="10dp"
                android:src="@drawable/icon_reading_speed" />

            <Button
                android:id="@+id/button_increase_speed"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_reading_button"
                android:foreground="@drawable/icon_arrow_right"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/text_current_speed"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Reading speed :&#10;100%"
                android:textColor="@color/white" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="@drawable/bg_surface_panel"
            android:padding="8dp"
            android:layout_weight="1"
            android:layout_marginBottom="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_previous_page"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_reading_button"
                android:foreground="@drawable/icon_arrow_left"
                android:textColor="@color/white" />

            <ImageView
                android:id="@+id/icon_view_page"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="6dp"
                android:layout_weight="1"
                android:padding="10dp"
                android:src="@drawable/icon_page" />

            <Button
                android:id="@+id/button_next_page"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_reading_button"
                android:foreground="@drawable/icon_arrow_right"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/text_current_page"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Page :&#10;120 / 333"
                android:textColor="@color/white" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="@drawable/bg_surface_panel"
            android:padding="8dp"
            android:layout_weight="1"
            android:layout_marginBottom="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_rewind_word"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_reading_button"
                android:foreground="@drawable/icon_arrow_left"
                android:textColor="@color/white" />

            <ImageView
                android:id="@+id/icon_view_word"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="6dp"
                android:layout_weight="1"
                android:padding="10dp"
                android:src="@drawable/word" />

            <Button
                android:id="@+id/button_jump_words"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_reading_button"
                android:foreground="@drawable/icon_arrow_right"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/text_current_words"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Words :&#10;42 / 66"
                android:textColor="@color/white" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="@drawable/bg_surface_panel"
            android:padding="8dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_save_bookmark"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_reading_button"
                android:foreground="@drawable/icon_save"
                android:textColor="@color/white" />

            <ImageView
                android:id="@+id/icon_view_bookmark"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="6dp"
                android:layout_weight="1"
                android:padding="10dp"
                android:src="@drawable/icon_bookmark" />

            <Button
                android:id="@+id/button_load_bookmark"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_reading_button"
                android:foreground="@drawable/icon_load"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/text_current_bookmark"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Bookmarks :&#10;3"
                android:textColor="@color/white" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>